# --- Neon (owner role, used only for migrations and role setup) ---
# Grab the pooled connection string from your Neon dashboard.
# Format: postgresql://<owner_user>:<password>@<host>-pooler.<region>.aws.neon.tech/aura?sslmode=require
NEON_OWNER_URL=

# --- Tenant-scoped connection strings (generated in step 1: setup-roles) ---
# After running `pnpm db:setup-roles`, paste the two URLs the script prints back.
# These point at the same database but connect as the limited Postgres roles.
APP_USER_URL=
APP_ADMIN_URL=

# --- Optional: passwords used when creating the limited roles ---
# Leave blank to have the setup script generate strong random passwords for you
# and print the final connection strings. Set explicit values only if you want
# to match an existing secret manager.
APP_USER_PASSWORD=
APP_ADMIN_PASSWORD=
